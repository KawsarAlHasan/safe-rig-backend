model CardSubmission {
  id Int @id @default(autoincrement())

  company           Company      @relation(fields: [companyId], references: [id])
  companyId         Int
  rig               Rig          @relation(fields: [rigId], references: [id])
  rigId             Int
  user              User         @relation(fields: [userId], references: [id])
  userId            Int
  cardType          CardType     @relation(fields: [cardTypeId], references: [id])
  cardTypeId        Int
  area              Area         @relation(fields: [areaId], references: [id])
  areaId            Int
  hazard            Hazard       @relation(fields: [hazardId], references: [id])
  hazardId          Int
  description       String
  riskSeverity      RiskSeverity
  file              String?
  fileType          String?
  actionTaken       Boolean      @default(false)
  immediateAction   Boolean      @default(false)
  submitAnonymously Boolean      @default(false)
  isOpened          Boolean      @default(false)
  closureNotes      String?
  evidence          String?
  submitDay         String?

  status    AllStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}
