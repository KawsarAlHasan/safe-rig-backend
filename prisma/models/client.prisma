model Client {
    id           Int       @id @default(autoincrement())
    email        String    @unique
    name         String?
    phone        String?
    profilePic   String?
    password     String
    status       AllStatus @default(ACTIVE)
    isMainClient Boolean   @default(false)

    company   Company? @relation(fields: [companyId], references: [id])
    companyId Int

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt


    @@unique([companyId, isMainClient(map: "only_one_main_per_company")])
}
