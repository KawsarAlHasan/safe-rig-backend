model Company {
    id        Int       @id @default(autoincrement())
    name      String    @unique
    email     String?
    phone     String?
    logo      String?
    status    AllStatus @default(ACTIVE)
    clients   Client[]

    alerts    Alert[]
    areas     Area[]
    cardTypes CardType[]
    hazards   Hazard[]
    messages  Message[]
    rigTypes  RigType[]
    videos    Videos[]
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}
