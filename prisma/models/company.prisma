model Company {
    id     Int       @id @default(autoincrement())
    name   String    @unique
    email  String?
    phone  String?
    logo   String?
    status AllStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    clients Client[]
    users   User[]

    rigs Rig[]

    alerts    Alert[]
    areas     Area[]
    cardTypes CardType[]
    hazards   Hazard[]
    messages  Message[]
    rigTypes  RigType[]
    videos    Videos[]

    activitys      Activity[]
    typeOfDevriefs TypeOfDevrief[]

    cardSubmissions CardSubmission[]
    dailyDebriefs   DailyDebrief[]
    heatmap         Heatmap[]
}
