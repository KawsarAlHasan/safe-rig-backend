model QuestionAnwser {
    id Int @id @default(autoincrement())

    image         String?
    question      String
    option1       String?
    option2       String?
    option3       String?
    option4       String?
    correctAnswer Int
    time          Int
    isUsed        Boolean @default(false)

    status AllStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    GameScheduleQuestions GameScheduleQuestion[]
}
