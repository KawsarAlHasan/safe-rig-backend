model Plan {
    id            Int    @id @default(autoincrement())
    name          String @unique
    monthlyPrice  Float?
    quarterPrice  Float?
    sixMonthPrice Float?
    yearlyPrice   Float?

    status AllStatus @default(ACTIVE)

    features Json?
    coupons  Coupon[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
