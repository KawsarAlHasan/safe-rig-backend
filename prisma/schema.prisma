generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AllStatus {
  ACTIVE
  PENDING
  INACTIVE
  SUSPENDED
  DELETED
  NOT_SUBMITTED
}

